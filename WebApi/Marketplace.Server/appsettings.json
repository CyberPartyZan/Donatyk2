{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=Marketplace;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "Redis": {
    "CacheExpirationMinutes": 10
  },
  "Payments": {
    "Provider": "Stripe",
    "BaseUrl": "https://payments.local"
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": "",
    "Provider": "Stripe"
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY",
    "FromEmail": "no-reply@marketplace.local",
    "FromName": "Marketplace"
  },
  "MassTransit": {
    "EndpointPrefix": "marketplace"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "Marketplace.Server",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "AllowedHosts": "*",
  "MinIO": {
    "Endpoint": "localhost:9000",
    "Login": "minioadmin",
    "Password": "minioadmin",
    "BucketName": "marketplace-media",
    "UseSsl": false
  }
}
